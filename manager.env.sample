# Manager bot settings
MANAGER_API_ID=
MANAGER_API_HASH=
MANAGER_BOT_TOKEN=
MANAGER_OWNER_ID=
# Optional comma- or space-separated Telegram user IDs.
MANAGER_SUDOERS=

# Optional defaults for new deployments
MANAGER_DEFAULT_MONGO_URL=
MANAGER_API_KEY=
# Optional shared cache defaults pushed into every deployed bot.
MANAGER_DOWNLOADS_PATH=downloads
MANAGER_COOKIES_PATH=cookies
# Optional shared batbin.me cookie URL(s), separated by spaces.
MANAGER_COOKIES_URL=

# Where deployments are tracked
DEPLOYMENTS_DIR=deployments
TEMPLATE_PATH=.

# Deployment health monitoring and bounded automatic recovery
MANAGER_MONITOR_INTERVAL=20
MANAGER_HEALTH_STALE_AFTER=120
MANAGER_HEALTH_CONFIRMATIONS=2
MANAGER_RECOVERY_LIMIT=3
MANAGER_RECOVERY_WINDOW=3600

# Daily owner recovery backup interval (seconds)
MANAGER_BACKUP_INTERVAL=86400
